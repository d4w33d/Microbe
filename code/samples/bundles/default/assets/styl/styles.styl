
c = #00ff99

:root
  font-size 14px

body
  margin 0
  padding 1rem
  background #111
  color #eee
  font-family monospace

body, td, th
  font-size 1rem

h1
  margin 0 0 1rem 0
  text-transform uppercase
  font-weight bold
  font-size 1.5rem
  small
    text-transform none
    font-weight normal
    font-size 1rem

a
  color c
  text-decoration underline
  &:hover
    color white

table
  border-collapse collapse
  border 3px solid c
  th, td
    padding 5px
    border 1px solid #333
